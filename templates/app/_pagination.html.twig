{% if totalPages > 1 %}
<nav aria-label="Seitennavigation" class="mt-3">
    <ul class="pagination justify-content-center">
        <li class="page-item {% if page <= 1 %}disabled{% endif %}">
            <a class="page-link" href="?page={{ page - 1 }}" aria-label="{% trans %}Vorherige{% endtrans %}">
                <span aria-hidden="true">&laquo;</span>
            </a>
        </li>

        {% for p in range(max(1, page - 2), min(totalPages, page + 2)) %}
            <li class="page-item {% if p == page %}active{% endif %}">
                <a class="page-link" href="?page={{ p }}">{{ p }}</a>
            </li>
        {% endfor %}

        <li class="page-item {% if page >= totalPages %}disabled{% endif %}">
            <a class="page-link" href="?page={{ page + 1 }}" aria-label="{% trans %}Nächste{% endtrans %}">
                <span aria-hidden="true">&raquo;</span>
            </a>
        </li>
    </ul>
    <p class="text-center text-muted small">{% trans %}Seite{% endtrans %} {{ page }} / {{ totalPages }}</p>
</nav>
{% endif %}
