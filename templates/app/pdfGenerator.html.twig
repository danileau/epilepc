<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>PDF-Übersicht vom {{ date }} - {{ app.user.firstname }} {{ app.user.lastname }}</title>
    <link href="{{ asset('application/vendor/fontawesome-free/css/all.css') }}" rel="stylesheet" type="text/css">
    <link href="{{ asset('application/css/sb-admin-2.css') }}" rel="stylesheet">
    <link rel="shortcut icon" type="image/png" href="{{ asset('landing/images/favicon.ico') }}"/>
    <style>
        body { background: #f8f9fc; font-family: 'Nunito', -apple-system, sans-serif; }
        .status-wrap { max-width: 800px; margin: 60px auto; text-align: center; }
        .progress-text { color: #858796; font-size: 0.95rem; margin-top: 12px; }
        .chart-render-area { position: absolute; left: -9999px; top: 0; }
        .chart-render-area canvas { display: block; }
        .done-area { display: none; }
    </style>
</head>
<body>

    <div class="status-wrap" id="statusArea">
        <img src="{{ asset('application/img/epilepc-color.png') }}" style="width: 300px; margin-bottom: 30px;" />

        <div id="progressArea">
            <h4 class="text-gray-800">{% trans %}PDF wird generiert{% endtrans %}...</h4>
            <div class="progress mt-4" style="height: 24px;">
                <div class="progress-bar bg-primary" id="progressBar" role="progressbar" style="width: 0%;">0%</div>
            </div>
            <p class="progress-text" id="progressText">{% trans %}Diagramme werden gerendert{% endtrans %}...</p>
        </div>

        <div id="doneArea" class="done-area">
            <h4 class="text-success"><i class="fas fa-check-circle"></i> {% trans %}PDF wurde erstellt{% endtrans %}!</h4>
            <p class="progress-text">{% trans %}Die Datei wurde heruntergeladen{% endtrans %}.</p>
            <button class="btn btn-primary mt-3" id="btnRetry">{% trans %}Erneut herunterladen{% endtrans %}</button>
            <button class="btn btn-secondary mt-3" id="btnClose">{% trans %}Fenster schliessen{% endtrans %}</button>
        </div>
    </div>

    {# Off-screen canvases — 2x resolution for crisp PDF output #}
    <div class="chart-render-area">
        <canvas id="chart1Year" width="1400" height="600"></canvas>
        <canvas id="chart2Years" width="1400" height="600"></canvas>
    </div>
    {# Hidden logo for embedding in PDF #}
    <img id="logoImg" src="{{ asset('application/img/epilepc-color.png') }}" style="display:none" crossorigin="anonymous" />

    <script src="{{ asset('application/vendor/jquery/jquery.min.js') }}"></script>
    <script src="{{ asset('application/vendor/chart.js/Chart.min.js') }}"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.4/jspdf.plugin.autotable.min.js"></script>

    <script type="text/javascript">
    (function() {
        var chartsReady = 0;
        var totalCharts = 2;

        function setProgress(pct, text) {
            document.getElementById('progressBar').style.width = pct + '%';
            document.getElementById('progressBar').textContent = pct + '%';
            if (text) document.getElementById('progressText').textContent = text;
        }

        function onChartComplete() {
            chartsReady++;
            var pct = Math.round((chartsReady / totalCharts) * 60);
            setProgress(pct, chartsReady + ' / ' + totalCharts + ' {% trans %}Diagramme fertig{% endtrans %}');
            if (chartsReady === totalCharts) {
                setTimeout(buildPDF, 200);
            }
        }

        // ── Chart.js shared config ────────────────────────────────

        var animOpts = { duration: 600, onComplete: onChartComplete };

        var yAxesConfig = [{
            ticks: {
                beginAtZero: true, maxTicksLimit: 5, padding: 10,
                callback: function(v) { if (v % 1 === 0) return v; }
            },
            gridLines: { color: "rgb(234,236,244)", zeroLineColor: "rgb(234,236,244)", drawBorder: false, borderDash: [2], zeroLineBorderDash: [2] }
        }];

        var seizureStyle  = { label: "{% trans %}Anfälle{% endtrans %}",      lineTension: 0.3, backgroundColor: "rgba(231,74,59,0.05)",  borderColor: "rgba(231,74,59,1)",  pointRadius: 3, pointBackgroundColor: "rgba(231,74,59,1)",  pointBorderColor: "rgba(231,74,59,1)",  pointBorderWidth: 2 };
        var eventStyle     = { label: "{% trans %}Ereignisse{% endtrans %}",   lineTension: 0.3, backgroundColor: "rgba(28,200,138,0.05)", borderColor: "rgba(28,200,138,1)", pointRadius: 3, pointBackgroundColor: "rgba(28,200,138,1)", pointBorderColor: "rgba(28,200,138,1)", pointBorderWidth: 2 };
        var medicationStyle = { label: "{% trans %}Medikationen{% endtrans %}", lineTension: 0.3, backgroundColor: "rgba(246,194,62,0.05)", borderColor: "rgba(246,194,62,1)", pointRadius: 3, pointBackgroundColor: "rgba(246,194,62,1)", pointBorderColor: "rgba(246,194,62,1)", pointBorderWidth: 2 };

        function ds(style, data) { var o = {}; for (var k in style) o[k] = style[k]; o.data = data; return o; }

        // 1-Year Chart
        new Chart(document.getElementById("chart1Year").getContext('2d'), {
            type: 'line',
            data: {
                labels: {{ seizure_month_1|raw }},
                datasets: [
                    ds(seizureStyle, {{ seizure_data_1|raw }}),
                    ds(eventStyle, {{ event_data_1|raw }}),
                    ds(medicationStyle, {{ medication_data_1|raw }})
                ]
            },
            options: {
                responsive: false, animation: animOpts, maintainAspectRatio: false,
                layout: { padding: { left: 15, right: 30, top: 20, bottom: 10 } },
                scales: {
                    xAxes: [{ gridLines: { display: false, drawBorder: false }, ticks: { maxTicksLimit: 12, fontSize: 11, fontColor: '#858796' } }],
                    yAxes: yAxesConfig
                },
                legend: { display: true, position: 'bottom', labels: { fontColor: '#5a5c69', fontSize: 12, padding: 20 } },
                tooltips: { enabled: false }
            }
        });

        // 2-Year Chart
        new Chart(document.getElementById("chart2Years").getContext('2d'), {
            type: 'line',
            data: {
                labels: {{ seizure_month|raw }},
                datasets: [
                    ds(seizureStyle, {{ seizure_data|raw }}),
                    ds(eventStyle, {{ event_data|raw }}),
                    ds(medicationStyle, {{ medication_data|raw }})
                ]
            },
            options: {
                responsive: false, animation: animOpts, maintainAspectRatio: false,
                layout: { padding: { left: 15, right: 30, top: 20, bottom: 10 } },
                scales: {
                    xAxes: [{ gridLines: { display: false, drawBorder: false }, ticks: { autoSkip: true, maxTicksLimit: 12, fontSize: 11, fontColor: '#858796' } }],
                    yAxes: yAxesConfig
                },
                legend: { display: true, position: 'bottom', labels: { fontColor: '#5a5c69', fontSize: 12, padding: 20 } },
                tooltips: { enabled: false }
            }
        });

        // ── PDF builder — matches webapp card-based UI ─────────────

        // Brand colors from sb-admin-2 / overview page
        var C = {
            primary: [78, 115, 223],
            danger:  [231, 74, 59],
            success: [28, 200, 138],
            warning: [246, 194, 62],
            gray800: [90, 92, 105],
            gray600: [133, 135, 150],
            gray300: [221, 223, 235],
            cardBg:  [255, 255, 255],
            pageBg:  [248, 249, 252],
            headerBg: [247, 247, 247]
        };

        function drawCard(doc, x, y, w, h) {
            // Shadow
            doc.setFillColor(200, 200, 210);
            doc.roundedRect(x + 0.5, y + 0.5, w, h, 1.5, 1.5, 'F');
            // Card body
            doc.setFillColor.apply(doc, C.cardBg);
            doc.roundedRect(x, y, w, h, 1.5, 1.5, 'F');
        }

        function drawCardHeader(doc, x, y, w, title) {
            doc.setFillColor(247, 247, 247);
            doc.roundedRect(x, y, w, 9, 1.5, 1.5, 'F');
            // Fill bottom corners (header is only top-rounded)
            doc.rect(x, y + 5, w, 4, 'F');
            // Bottom border
            doc.setDrawColor(230, 230, 230);
            doc.setLineWidth(0.2);
            doc.line(x, y + 9, x + w, y + 9);
            // Title text
            doc.setFontSize(9);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor.apply(doc, C.gray600);
            doc.text(title, x + 4, y + 6);
            doc.setFont('helvetica', 'normal');
        }

        function buildPDF() {
            setProgress(65, '{% trans %}PDF wird zusammengesetzt{% endtrans %}...');

            var jsPDF = window.jspdf.jsPDF;
            var doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
            var pageW = doc.internal.pageSize.getWidth();
            var pageH = doc.internal.pageSize.getHeight();
            var m = 12; // margin
            var cw = pageW - m * 2; // content width
            var y = m;

            // Page background
            doc.setFillColor.apply(doc, C.pageBg);
            doc.rect(0, 0, pageW, pageH, 'F');

            // ── Header with logo ──────────────────────────────────

            var logoEl = document.getElementById('logoImg');
            var logoCanvas = document.createElement('canvas');
            logoCanvas.width = logoEl.naturalWidth;
            logoCanvas.height = logoEl.naturalHeight;
            logoCanvas.getContext('2d').drawImage(logoEl, 0, 0);
            var logoData = logoCanvas.toDataURL('image/png');

            var logoH = 12;
            var logoW = logoH * (logoEl.naturalWidth / logoEl.naturalHeight);
            doc.addImage(logoData, 'PNG', m, y, logoW, logoH);

            var textX = m + logoW + 4;
            doc.setFontSize(10);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor.apply(doc, C.gray600);
            doc.text('{% trans %}PDF-Übersicht vom{% endtrans %} {{ date }}', textX, y + 5);
            doc.text('{{ app.user.firstname|e('js') }} {{ app.user.lastname|e('js') }}', textX, y + 10);

            {% if diagnose is not null %}
            doc.setFontSize(9);
            doc.setTextColor.apply(doc, C.gray800);
            doc.text('{% trans %}Diagnose{% endtrans %}: {{ diagnose|e('js') }}', m, y + 18);
            y += 24;
            {% else %}
            y += 16;
            {% endif %}

            // Divider
            doc.setDrawColor.apply(doc, C.gray300);
            doc.setLineWidth(0.3);
            doc.line(m, y, m + cw, y);
            y += 6;

            // ── 1-Year Chart Card (full width) ───────────────────

            setProgress(70, '{% trans %}Diagramme werden eingebettet{% endtrans %}...');

            var chartCardH = 78;
            var imgPad = 3;
            drawCard(doc, m, y, cw, chartCardH);
            drawCardHeader(doc, m, y, cw, '{% trans %}Deine Übersicht der letzten 12 Monate{% endtrans %}');

            var chart1Img = document.getElementById('chart1Year').toDataURL('image/png');
            var imgW = cw - imgPad * 2;
            var imgH = chartCardH - 9 - imgPad * 2;
            doc.addImage(chart1Img, 'PNG', m + imgPad, y + 9 + imgPad, imgW, imgH);

            y += chartCardH + 3;

            // 12-month summary counts
            doc.setFontSize(8);
            var items1y = [
                { label: '{% trans %}Anfälle{% endtrans %}', count: {{ seizure_count_1y }}, color: C.danger },
                { label: '{% trans %}Ereignisse{% endtrans %}', count: {{ event_count_1y }}, color: C.success },
                { label: '{% trans %}Medikationen{% endtrans %}', count: {{ medication_count_1y }}, color: C.warning }
            ];
            var sx1 = m;
            for (var i = 0; i < items1y.length; i++) {
                doc.setFillColor.apply(doc, items1y[i].color);
                doc.circle(sx1 + 1.5, y + 1, 1.5, 'F');
                doc.setTextColor.apply(doc, C.gray800);
                doc.text(items1y[i].label + ': ' + items1y[i].count, sx1 + 5, y + 2);
                sx1 += 45;
            }

            y += 8;

            // ── 2-Year Chart Card (full width) ────────────────────

            setProgress(80, '{% trans %}Diagramme werden eingebettet{% endtrans %}...');

            var chart2H = 72;
            drawCard(doc, m, y, cw, chart2H);
            drawCardHeader(doc, m, y, cw, '{% trans %}Deine Übersicht der letzten 2 Jahren{% endtrans %}');

            var chart2Img = document.getElementById('chart2Years').toDataURL('image/png');
            var img2W = cw - imgPad * 2;
            var img2H = chart2H - 9 - imgPad * 2;
            doc.addImage(chart2Img, 'PNG', m + imgPad, y + 9 + imgPad, img2W, img2H);

            y += chart2H + 6;

            // ── Summary counts (like the pie chart legend) ────────

            doc.setFontSize(8);
            var summaryY = y + 2;
            var items = [
                { label: '{% trans %}Anfälle{% endtrans %}', count: {{ seizure_count }}, color: C.danger },
                { label: '{% trans %}Ereignisse{% endtrans %}', count: {{ event_count }}, color: C.success },
                { label: '{% trans %}Medikationen{% endtrans %}', count: {{ medication_count }}, color: C.warning }
            ];
            var sx = m;
            for (var i = 0; i < items.length; i++) {
                doc.setFillColor.apply(doc, items[i].color);
                doc.circle(sx + 1.5, summaryY - 1, 1.5, 'F');
                doc.setTextColor.apply(doc, C.gray800);
                doc.text(items[i].label + ': ' + items[i].count, sx + 5, summaryY);
                sx += 45;
            }

            // ── Page 2+: Data Table ───────────────────────────────

            setProgress(90, '{% trans %}Tabelle wird erstellt{% endtrans %}...');
            doc.addPage();

            // Page background
            doc.setFillColor.apply(doc, C.pageBg);
            doc.rect(0, 0, pageW, pageH, 'F');

            // Section header
            doc.setFontSize(12);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor.apply(doc, C.gray800);
            doc.text('{% trans %}Erfasste Daten{% endtrans %}', m, m + 5);
            doc.setFont('helvetica', 'normal');

            var tableRows = [];
            {% for seizure in seizures %}
            tableRows.push({
                date: '{{ seizure.timestamp_when|date('d.m.Y H:i') }}',
                title: '{{ seizure.title|e('js') }}{% if seizure.seizuretype_name %} - {{ seizure.seizuretype_name|e('js') }}{% endif %}',
                type: '{% trans %}Anfall{% endtrans %}',
                typeColor: [231, 74, 59],
                rowTint: [253, 243, 242]
            });
            {% endfor %}
            {% for event in events %}
            tableRows.push({
                date: '{{ event.timestamp_when|date('d.m.Y H:i') }}',
                title: '{{ event.name|e('js') }}',
                type: '{% trans %}Ereignis{% endtrans %}',
                typeColor: [28, 200, 138],
                rowTint: [240, 252, 247]
            });
            {% endfor %}
            {% for medication in medications %}
            tableRows.push({
                date: '{{ medication.timestamp_prescription|date('d.m.Y H:i') }}',
                title: '{{ medication.name|e('js') }}',
                type: '{% trans %}Medikation{% endtrans %}',
                typeColor: [246, 194, 62],
                rowTint: [255, 251, 239]
            });
            {% endfor %}

            // Sort by date descending
            tableRows.sort(function(a, b) {
                var pa = a.date.split(/[.\s:]/), pb = b.date.split(/[.\s:]/);
                var da = new Date(pa[2], pa[1]-1, pa[0], pa[3]||0, pa[4]||0);
                var db = new Date(pb[2], pb[1]-1, pb[0], pb[3]||0, pb[4]||0);
                return db - da;
            });

            // Convert to autoTable format, keep metadata for styling
            var bodyRows = [];
            var rowMeta = [];
            for (var r = 0; r < tableRows.length; r++) {
                bodyRows.push([tableRows[r].date, tableRows[r].title, tableRows[r].type]);
                rowMeta.push(tableRows[r]);
            }

            var lastContentPage = doc.internal.getNumberOfPages();

            doc.autoTable({
                startY: m + 10,
                margin: { left: m, right: m },
                head: [['{% trans %}Datum{% endtrans %}', '{% trans %}Titel{% endtrans %}', '{% trans %}Typ{% endtrans %}']],
                body: bodyRows,
                styles: {
                    fontSize: 8,
                    cellPadding: { top: 2.5, right: 3, bottom: 2.5, left: 3 },
                    overflow: 'linebreak',
                    font: 'helvetica',
                    textColor: [90, 92, 105],
                    lineColor: [221, 223, 235],
                    lineWidth: 0.15
                },
                headStyles: {
                    fillColor: [78, 115, 223],
                    textColor: 255,
                    fontStyle: 'bold',
                    fontSize: 8.5
                },
                columnStyles: {
                    0: { cellWidth: 32, fontStyle: 'normal' },
                    1: { cellWidth: 'auto' },
                    2: { cellWidth: 26, halign: 'center', fontStyle: 'bold' }
                },
                didParseCell: function(data) {
                    if (data.section === 'body') {
                        var meta = rowMeta[data.row.index];
                        if (meta) {
                            // Light tinted row background matching entity color
                            data.cell.styles.fillColor = meta.rowTint;
                            // Type column gets the bold entity color
                            if (data.column.index === 2) {
                                data.cell.styles.textColor = meta.typeColor;
                            }
                        }
                    }
                },
                didDrawCell: function(data) {
                    if (data.section === 'body') {
                        lastContentPage = doc.internal.getNumberOfPages();
                    }
                },
                didDrawPage: function(data) {
                    // Re-draw page background for continuation pages
                    if (data.pageNumber > 1) {
                        doc.setFillColor.apply(doc, C.pageBg);
                        doc.rect(0, 0, pageW, pageH, 'F');
                    }
                }
            });

            // ── Remove trailing blank pages autoTable may have added ─

            var totalPages = doc.internal.getNumberOfPages();
            while (totalPages > lastContentPage) {
                doc.deletePage(totalPages);
                totalPages--;
            }

            // ── Footer on every page ──────────────────────────────
            for (var p = 1; p <= totalPages; p++) {
                doc.setPage(p);
                // Footer divider
                doc.setDrawColor.apply(doc, C.gray300);
                doc.setLineWidth(0.2);
                doc.line(m, pageH - 12, m + cw, pageH - 12);
                // Footer text
                doc.setFontSize(7.5);
                doc.setTextColor.apply(doc, C.gray600);
                doc.text('epilepc.ch', m, pageH - 8);
                doc.text(
                    '{% trans %}Seite{% endtrans %} ' + p + ' / ' + totalPages,
                    pageW - m, pageH - 8,
                    { align: 'right' }
                );
            }

            // ── Save ──────────────────────────────────────────────

            setProgress(100, '{% trans %}PDF wird heruntergeladen{% endtrans %}...');

            var d = new Date();
            var dateStr = ('0'+d.getDate()).slice(-2) + '-' + ('0'+(d.getMonth()+1)).slice(-2) + '-' + d.getFullYear();
            var filename = 'epilepc-export-{{ app.user.firstname|e('js') }}-{{ app.user.lastname|e('js') }}-' + dateStr + '.pdf';

            doc.save(filename);

            document.getElementById('progressArea').style.display = 'none';
            document.getElementById('doneArea').style.display = 'block';
        }

        document.getElementById('btnRetry').addEventListener('click', function() {
            document.getElementById('doneArea').style.display = 'none';
            document.getElementById('progressArea').style.display = 'block';
            setProgress(0, '{% trans %}PDF wird generiert{% endtrans %}...');
            buildPDF();
        });
        document.getElementById('btnClose').addEventListener('click', function() {
            window.close();
        });

    })();
    </script>
</body>
</html>
