<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>PDF-Übersicht vom {{ date }} - {{ app.user.firstname }} {{ app.user.lastname }}</title>
    <link href="{{ asset('application/vendor/fontawesome-free/css/all.css') }}" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <link href="{{ asset('application/css/sb-admin-2.css') }}" rel="stylesheet">
    <link rel="shortcut icon" type="image/png" href="{{ asset('landing/images/favicon.ico') }}"/>
    <style>
        body {
            background: #f8f9fc;
            font-family: 'Nunito', sans-serif;
        }
        .status-wrap {
            max-width: 800px;
            margin: 60px auto;
            text-align: center;
        }
        .progress-text {
            color: #858796;
            font-size: 0.95rem;
            margin-top: 12px;
        }
        .chart-render-area {
            position: absolute;
            left: -9999px;
            top: 0;
        }
        .chart-render-area canvas {
            display: block;
        }
        .done-area { display: none; }
    </style>
</head>
<body>

    <div class="status-wrap" id="statusArea">
        <img src="{{ asset('application/img/epilepc-color.png') }}" style="width: 300px; margin-bottom: 30px;" />

        <div id="progressArea">
            <h4 class="text-gray-800">{% trans %}PDF wird generiert{% endtrans %}...</h4>
            <div class="progress mt-4" style="height: 24px;">
                <div class="progress-bar bg-primary" id="progressBar" role="progressbar" style="width: 0%;">0%</div>
            </div>
            <p class="progress-text" id="progressText">{% trans %}Diagramme werden gerendert{% endtrans %}...</p>
        </div>

        <div id="doneArea" class="done-area">
            <h4 class="text-success"><i class="fas fa-check-circle"></i> {% trans %}PDF wurde erstellt{% endtrans %}!</h4>
            <p class="progress-text">{% trans %}Die Datei wurde heruntergeladen{% endtrans %}.</p>
            <button class="btn btn-primary mt-3" id="btnRetry">{% trans %}Erneut herunterladen{% endtrans %}</button>
            <button class="btn btn-secondary mt-3" id="btnClose">{% trans %}Fenster schliessen{% endtrans %}</button>
        </div>
    </div>

    {# Off-screen area where Chart.js renders — never visible to user #}
    <div class="chart-render-area">
        <canvas id="chart1Year" width="1600" height="500"></canvas>
        <canvas id="chartPie" width="800" height="500"></canvas>
        <canvas id="chart2Years" width="1600" height="500"></canvas>
    </div>

    <script src="{{ asset('application/vendor/jquery/jquery.min.js') }}"></script>
    <script src="{{ asset('application/vendor/chart.js/Chart.min.js') }}"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.4/jspdf.plugin.autotable.min.js"></script>

    <script type="text/javascript">
    (function() {
        var chartsReady = 0;
        var totalCharts = 3;

        function setProgress(pct, text) {
            document.getElementById('progressBar').style.width = pct + '%';
            document.getElementById('progressBar').textContent = pct + '%';
            if (text) document.getElementById('progressText').textContent = text;
        }

        function onChartComplete() {
            chartsReady++;
            var pct = Math.round((chartsReady / totalCharts) * 60);
            setProgress(pct, chartsReady + ' / ' + totalCharts + ' {% trans %}Diagramme fertig{% endtrans %}');

            if (chartsReady === totalCharts) {
                setTimeout(buildPDF, 200);
            }
        }

        // ── Chart.js configuration ─────────────────────────────────

        var animOpts = {
            duration: 600,
            onComplete: onChartComplete
        };

        var lineChartOptions = {
            responsive: false,
            animation: animOpts,
            maintainAspectRatio: false,
            layout: { padding: { left: 10, right: 25, top: 25, bottom: 0 } },
            scales: {
                xAxes: [{ gridLines: { display: false, drawBorder: false }, ticks: { maxTicksLimit: 7 } }],
                yAxes: [{
                    ticks: {
                        beginAtZero: true, maxTicksLimit: 5, padding: 10,
                        callback: function(v) { if (v % 1 === 0) return v; }
                    },
                    gridLines: { color: "rgb(234,236,244)", zeroLineColor: "rgb(234,236,244)", drawBorder: false, borderDash: [2], zeroLineBorderDash: [2] }
                }]
            },
            legend: { display: true, position: 'bottom', labels: { fontColor: 'black', fontSize: 13 } },
            tooltips: { enabled: false }
        };

        // 1-Year Chart
        new Chart(document.getElementById("chart1Year").getContext('2d'), {
            type: 'line',
            data: {
                labels: {{ seizure_month_1|raw }},
                datasets: [
                    { label: "{% trans %}Anfälle{% endtrans %}", lineTension: 0.3, backgroundColor: "rgba(231,74,59,0.05)", borderColor: "rgba(231,74,59,1)", pointRadius: 3, pointBackgroundColor: "rgba(231,74,59,1)", pointBorderColor: "rgba(231,74,59,1)", pointBorderWidth: 2, data: {{ seizure_data_1|raw }} },
                    { label: "{% trans %}Ereignisse{% endtrans %}", lineTension: 0.3, backgroundColor: "rgba(28,200,138,0.05)", borderColor: "rgba(28,200,138,1)", pointRadius: 3, pointBackgroundColor: "rgba(28,200,138,1)", pointBorderColor: "rgba(28,200,138,1)", pointBorderWidth: 2, data: {{ event_data_1|raw }} },
                    { label: "{% trans %}Medikationen{% endtrans %}", lineTension: 0.3, backgroundColor: "rgba(246,194,62,0.05)", borderColor: "rgba(246,194,62,1)", pointRadius: 3, pointBackgroundColor: "rgba(246,194,62,1)", pointBorderColor: "rgba(246,194,62,1)", pointBorderWidth: 2, data: {{ medication_data_1|raw }} }
                ]
            },
            options: lineChartOptions
        });

        // 2-Year Chart
        new Chart(document.getElementById("chart2Years").getContext('2d'), {
            type: 'line',
            data: {
                labels: {{ seizure_month|raw }},
                datasets: [
                    { label: "{% trans %}Anfälle{% endtrans %}", lineTension: 0.3, backgroundColor: "rgba(231,74,59,0.05)", borderColor: "rgba(231,74,59,1)", pointRadius: 3, pointBackgroundColor: "rgba(231,74,59,1)", pointBorderColor: "rgba(231,74,59,1)", pointBorderWidth: 2, data: {{ seizure_data|raw }} },
                    { label: "{% trans %}Ereignisse{% endtrans %}", lineTension: 0.3, backgroundColor: "rgba(28,200,138,0.05)", borderColor: "rgba(28,200,138,1)", pointRadius: 3, pointBackgroundColor: "rgba(28,200,138,1)", pointBorderColor: "rgba(28,200,138,1)", pointBorderWidth: 2, data: {{ event_data|raw }} },
                    { label: "{% trans %}Medikationen{% endtrans %}", lineTension: 0.3, backgroundColor: "rgba(246,194,62,0.05)", borderColor: "rgba(246,194,62,1)", pointRadius: 3, pointBackgroundColor: "rgba(246,194,62,1)", pointBorderColor: "rgba(246,194,62,1)", pointBorderWidth: 2, data: {{ medication_data|raw }} }
                ]
            },
            options: {
                responsive: false,
                animation: animOpts,
                maintainAspectRatio: false,
                layout: { padding: { left: 10, right: 25, top: 25, bottom: 0 } },
                scales: {
                    xAxes: [{ gridLines: { display: false, drawBorder: false }, ticks: { autoSkip: true, maxTicksLimit: 12 } }],
                    yAxes: [{
                        ticks: {
                            beginAtZero: true, maxTicksLimit: 5, padding: 10,
                            callback: function(v) { if (v % 1 === 0) return v; }
                        },
                        gridLines: { color: "rgb(234,236,244)", zeroLineColor: "rgb(234,236,244)", drawBorder: false, borderDash: [2], zeroLineBorderDash: [2] }
                    }]
                },
                legend: { display: true, position: 'bottom', labels: { fontColor: 'black', fontSize: 13 } },
                tooltips: { enabled: false }
            }
        });

        // Pie Chart
        new Chart(document.getElementById("chartPie").getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ["{% trans %}Ereignisse{% endtrans %}", "{% trans %}Anfälle{% endtrans %}", "{% trans %}Medikationen{% endtrans %}"],
                datasets: [{ data: [{{ event_count }}, {{ seizure_count }}, {{ medication_count }}], backgroundColor: ['#1cc88a', '#e74a3b', '#f6c23e'] }]
            },
            options: {
                responsive: false,
                animation: animOpts,
                maintainAspectRatio: false,
                legend: { display: true, position: 'bottom', labels: { fontColor: 'black', fontSize: 13 } },
                tooltips: { enabled: false },
                cutoutPercentage: 65
            }
        });

        // ── PDF builder ────────────────────────────────────────────

        function buildPDF() {
            setProgress(65, '{% trans %}PDF wird zusammengesetzt{% endtrans %}...');

            var jsPDF = window.jspdf.jsPDF;
            var doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
            var pageW = doc.internal.pageSize.getWidth();
            var pageH = doc.internal.pageSize.getHeight();
            var margin = 15;
            var contentW = pageW - margin * 2;
            var y = margin;

            // ── Page 1: Header + 1-Year Chart + Pie Chart ──────────

            doc.setFontSize(18);
            doc.setTextColor(60, 60, 60);
            doc.text('epilepc', margin, y + 6);
            doc.setFontSize(10);
            doc.setTextColor(130, 130, 130);
            doc.text('{% trans %}PDF-Übersicht vom{% endtrans %} {{ date }}', margin, y + 13);
            doc.text('{{ app.user.firstname|e('js') }} {{ app.user.lastname|e('js') }}', margin, y + 18);

            {% if diagnose is not null %}
            doc.setFontSize(10);
            doc.setTextColor(80, 80, 80);
            doc.text('{% trans %}Diagnose{% endtrans %}: {{ diagnose|e('js') }}', margin, y + 25);
            y += 32;
            {% else %}
            y += 24;
            {% endif %}

            // 1-Year chart
            setProgress(70, '{% trans %}Diagramme werden eingebettet{% endtrans %}...');
            doc.setFontSize(12);
            doc.setTextColor(60, 60, 60);
            doc.text('{% trans %}Deine Übersicht vom letzten Jahr{% endtrans %}', margin, y);
            y += 3;
            var chart1Img = document.getElementById('chart1Year').toDataURL('image/png');
            var chart1H = (contentW / 1600) * 500;
            doc.addImage(chart1Img, 'PNG', margin, y, contentW, chart1H);
            y += chart1H + 8;

            // Pie chart
            doc.setFontSize(12);
            doc.text('{% trans %}Was wurde wie oft erfasst?{% endtrans %}', margin, y);
            y += 3;
            var pieImg = document.getElementById('chartPie').toDataURL('image/png');
            var pieW = contentW * 0.5;
            var pieH = (pieW / 800) * 500;
            doc.addImage(pieImg, 'PNG', margin + (contentW - pieW) / 2, y, pieW, pieH);

            // ── Page 2: 2-Year Chart ───────────────────────────────

            setProgress(80, '{% trans %}Diagramme werden eingebettet{% endtrans %}...');
            doc.addPage();
            y = margin;
            doc.setFontSize(12);
            doc.setTextColor(60, 60, 60);
            doc.text('{% trans %}Deine Übersicht der letzten 2 Jahren{% endtrans %}', margin, y);
            y += 3;
            var chart2Img = document.getElementById('chart2Years').toDataURL('image/png');
            var chart2H = (contentW / 1600) * 500;
            doc.addImage(chart2Img, 'PNG', margin, y, contentW, chart2H);

            // ── Page 3+: Data Table ────────────────────────────────

            setProgress(90, '{% trans %}Tabelle wird erstellt{% endtrans %}...');
            doc.addPage();

            doc.setFontSize(12);
            doc.setTextColor(60, 60, 60);
            doc.text('{% trans %}Erfasste Daten{% endtrans %}', margin, margin);

            var tableRows = [];
            {% for seizure in seizures %}
            tableRows.push([
                '{{ seizure.timestamp_when|date('d.m.Y H:i') }}',
                '{{ seizure.title|e('js') }}{% if seizure.seizuretype_name %} - {{ seizure.seizuretype_name|e('js') }}{% endif %}',
                '{% trans %}Anfall{% endtrans %}'
            ]);
            {% endfor %}
            {% for event in events %}
            tableRows.push([
                '{{ event.timestamp_when|date('d.m.Y H:i') }}',
                '{{ event.name|e('js') }}',
                '{% trans %}Ereignis{% endtrans %}'
            ]);
            {% endfor %}
            {% for medication in medications %}
            tableRows.push([
                '{{ medication.timestamp_prescription|date('d.m.Y H:i') }}',
                '{{ medication.name|e('js') }}',
                '{% trans %}Medikation{% endtrans %}'
            ]);
            {% endfor %}

            // Sort by date descending
            tableRows.sort(function(a, b) {
                var pa = a[0].split(/[.\s:]/), pb = b[0].split(/[.\s:]/);
                var da = new Date(pa[2], pa[1]-1, pa[0], pa[3]||0, pa[4]||0);
                var db = new Date(pb[2], pb[1]-1, pb[0], pb[3]||0, pb[4]||0);
                return db - da;
            });

            doc.autoTable({
                startY: margin + 5,
                margin: { left: margin, right: margin },
                head: [['{% trans %}Datum{% endtrans %}', '{% trans %}Beschreibung{% endtrans %}', '{% trans %}Typ{% endtrans %}']],
                body: tableRows,
                styles: {
                    fontSize: 8,
                    cellPadding: 2,
                    overflow: 'linebreak',
                    font: 'helvetica'
                },
                headStyles: {
                    fillColor: [78, 115, 223],
                    textColor: 255,
                    fontStyle: 'bold'
                },
                alternateRowStyles: {
                    fillColor: [245, 247, 250]
                },
                columnStyles: {
                    0: { cellWidth: 35 },
                    2: { cellWidth: 28 }
                },
                didParseCell: function(data) {
                    if (data.section === 'body' && data.column.index === 2) {
                        var typ = data.cell.raw;
                        if (typ === '{% trans %}Anfall{% endtrans %}') data.cell.styles.textColor = [231, 74, 59];
                        else if (typ === '{% trans %}Ereignis{% endtrans %}') data.cell.styles.textColor = [28, 200, 138];
                        else if (typ === '{% trans %}Medikation{% endtrans %}') data.cell.styles.textColor = [246, 194, 62];
                    }
                }
            });

            // ── Footer on every page ───────────────────────────────

            var totalPages = doc.internal.getNumberOfPages();
            for (var i = 1; i <= totalPages; i++) {
                doc.setPage(i);
                doc.setFontSize(8);
                doc.setTextColor(180, 180, 180);
                doc.text(
                    'epilepc.ch — {% trans %}Seite{% endtrans %} ' + i + ' / ' + totalPages,
                    pageW / 2, pageH - 8,
                    { align: 'center' }
                );
            }

            // ── Save ───────────────────────────────────────────────

            setProgress(100, '{% trans %}PDF wird heruntergeladen{% endtrans %}...');

            var d = new Date();
            var dateStr = ('0'+d.getDate()).slice(-2) + '-' + ('0'+(d.getMonth()+1)).slice(-2) + '-' + d.getFullYear();
            var filename = 'epilepc-export-{{ app.user.firstname|e('js') }}-{{ app.user.lastname|e('js') }}-' + dateStr + '.pdf';

            doc.save(filename);

            // Show completion UI
            document.getElementById('progressArea').style.display = 'none';
            document.getElementById('doneArea').style.display = 'block';
        }

        // Wire up done-area buttons
        document.getElementById('btnRetry').addEventListener('click', function() {
            document.getElementById('doneArea').style.display = 'none';
            document.getElementById('progressArea').style.display = 'block';
            setProgress(0, '{% trans %}PDF wird generiert{% endtrans %}...');
            buildPDF();
        });
        document.getElementById('btnClose').addEventListener('click', function() {
            window.close();
        });

    })();
    </script>
</body>
</html>
